<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        android:background="#000000"
        tools:context=".MainActivity">

    <FrameLayout
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
                android:id="@+id/subscriber_container"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent" />

        <FrameLayout
                android:id="@+id/publisher_container"
                android:layout_width="90dp"
                android:layout_height="120dp"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="16dp"
                android:layout_marginRight="16dp"
                android:layout_marginBottom="16dp"
                android:background="#FFFFFF"
                android:padding="2dp" />
    </FrameLayout>

    <TextView
        android:id="@+id/silent_auth_note"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:text="This verification temporarily uses your mobile network for Silent Authentication. If Silent Auth is not supported by your mobile operator, SMS verification will be used instead. Once verified, you will automatically join the Video session."
        android:textSize="18sp"
        android:textColor="#FFFFFF" />

    <EditText
        android:id="@+id/phone_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:minHeight="48dp"
        app:layout_constraintTop_toBottomOf="@id/silent_auth_note"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:hint="Phone number (447XXXXXXXXX)"
        android:inputType="phone"
        android:textColor="#FFFFFF"
        android:textColorHint="#888888"
        android:backgroundTint="#7B61FF" />

    <Button
        android:id="@+id/btn_start_verify"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:minHeight="48dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        app:layout_constraintTop_toBottomOf="@id/phone_input"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:text="Verify and Join"
        android:background="@drawable/btn_vonage"
        android:textAllCaps="false"
        android:textColor="#FFFFFF" />

    <EditText
        android:id="@+id/sms_code_input"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/btn_start_verify"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:hint="SMS code"
        android:inputType="number"
        android:visibility="gone"
        android:textColor="#FFFFFF"
        android:textColorHint="#888888"
        android:backgroundTint="#7B61FF" />

    <Button
        android:id="@+id/btn_confirm_sms"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minHeight="48dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:layout_marginTop="12dp"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toBottomOf="@id/sms_code_input"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:text="Verify and Join"
        android:visibility="gone"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:background="@drawable/btn_vonage" />

</androidx.constraintlayout.widget.ConstraintLayout>
